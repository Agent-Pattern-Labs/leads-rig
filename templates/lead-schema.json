{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:public-leads-harness:templates:lead-schema",
  "title": "Lead ingest payload",
  "description": "Portable payload for lead review or ingest APIs.",
  "type": "object",
  "additionalProperties": true,
  "required": ["leads"],
  "properties": {
    "jobId": {
      "type": "string",
      "description": "Optional stable crawl job ID. The app generates one when omitted."
    },
    "domains": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "leads": {
      "type": "array",
      "items": { "$ref": "#/$defs/lead" }
    },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/result" },
      "default": []
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  },
  "$defs": {
    "lead": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "domain",
        "emailType",
        "sourceUrl",
        "evidence",
        "extractionMethod",
        "verificationStatus",
        "confidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "company": { "type": "string" },
        "domain": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "contactName": { "type": "string" },
        "title": { "type": "string" },
        "email": { "type": "string" },
        "emailType": {
          "type": "string",
          "enum": ["person", "role", "blocked", "contact_path", "unknown"]
        },
        "sourceUrl": { "type": "string" },
        "sourceLabel": { "type": "string" },
        "evidence": { "type": "string" },
        "extractionMethod": { "type": "string" },
        "verificationStatus": {
          "type": "string",
          "enum": ["verified", "mx_verified", "unverified", "not_applicable", "blocked", "unknown"]
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "linkedinUrl": {
          "type": "string",
          "description": "Optional canonical public LinkedIn profile or organization URL."
        },
        "phone": {
          "type": "string",
          "description": "Optional normalized phone number found near the public contact evidence."
        },
        "address": {
          "type": "string",
          "description": "Optional complete public business address."
        },
        "streetAddress": {
          "type": "string",
          "description": "Optional street-address component."
        },
        "location": {
          "type": "string",
          "description": "Optional display location for the lead."
        },
        "city": { "type": "string" },
        "region": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" },
        "socialUrls": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Optional public social/profile URLs found on the same source page."
        },
        "contactUrls": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Optional public scheduling or contact URLs found on the same source page."
        },
        "foundAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": true,
      "required": ["domain"],
      "properties": {
        "domain": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "leads": {
          "type": "array",
          "items": { "$ref": "#/$defs/lead" },
          "default": []
        },
        "pages": {
          "type": "array",
          "items": { "$ref": "#/$defs/pageVisit" },
          "default": []
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "pageVisit": {
      "type": "object",
      "additionalProperties": true,
      "required": ["url"],
      "properties": {
        "url": { "type": "string" },
        "title": { "type": "string" },
        "statusCode": { "type": "integer" },
        "emailsFound": { "type": "integer" },
        "phonesFound": { "type": "integer" },
        "socialUrlsFound": { "type": "integer" },
        "contactUrlsFound": { "type": "integer" },
        "error": { "type": "string" }
      }
    }
  }
}
